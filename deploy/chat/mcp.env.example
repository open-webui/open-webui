# jawafdehi-mcp environment variables for chat.jawafdehi.org deployment
#
# Copy to mcp.env and fill in real values:
#   cp mcp.env.example mcp.env

# Base URL of the jawafdehi-api Django server.
# In production this points at the deployed API (e.g. https://portal.jawafdehi.org).
JAWAFDEHI_API_BASE_URL=https://portal.jawafdehi.org

# DRF token for the chat-jawafdehi-org service account.
# Generate on the jawafdehi-api server with:
#   python manage.py setup_chat_service_account
JAWAFDEHI_API_TOKEN=your_token_here

# NES API base URL (defaults to https://nes.jawafdehi.org if unset)
# NES_API_BASE_URL=https://nes.jawafdehi.org

# Log level: debug, info, warning, error. Default: info.
# LOG_LEVEL=info
