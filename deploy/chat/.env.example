# chat.jawafdehi.org — Environment variables for production deployment
#
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# WARNING: .env contains secrets. Never commit it to the repository.

WEBUI_NAME=Jawafdehi Chat
WEBUI_SECRET_KEY=generate-a-random-64-char-hex-string
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
OAUTH_CLIENT_INFO_ENCRYPTION_KEY=generate-a-random-base64-key
