# === Ruimtemeesters Browser Chatbot ===
# Copy this to .env and fill in your values:
#   cp .env.rm.example .env

# --- Compose ---
# Tells docker compose which file to use by default
COMPOSE_FILE=docker-compose.rm.yaml

# Port (default 3333)
OPEN_WEBUI_PORT=3333

# Secret key for JWT signing (generate with: openssl rand -hex 32)
WEBUI_SECRET_KEY=

# App branding
WEBUI_NAME=Ruimtemeesters AI

# --- Database ---
POSTGRES_USER=rmchatbot
POSTGRES_PASSWORD=rmchatbot
POSTGRES_DB=rmchatbot

# --- LLM Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Clerk OIDC ---
# 1. In Clerk Dashboard → OAuth applications → Add OAuth application
# 2. Set redirect URIs:
#    - http://localhost:3333/oauth/oidc/callback (dev)
#    - https://chatbot.datameesters.nl/oauth/oidc/callback (prod)
#    - https://rob.datameesters.nl/oauth/oidc/callback (prod)
# 3. Copy credentials below
CLERK_OIDC_DISCOVERY_URL=
CLERK_OAUTH_CLIENT_ID=
CLERK_OAUTH_CLIENT_SECRET=

# OAuth config
ENABLE_OAUTH_SIGNUP=true
OAUTH_PROVIDER_NAME=Clerk
OAUTH_SCOPES=openid profile email
OAUTH_USERNAME_CLAIM=email
OAUTH_EMAIL_CLAIM=email

# --- Clerk SSO (shared cookie from datameesters.nl) ---
# The Clerk secret key is needed to fetch user details from Clerk Backend API.
# Get it from Clerk Dashboard → API keys
CLERK_SECRET_KEY=
CLERK_JWKS_URI=https://clerk.datameesters.nl/.well-known/jwks.json
CLERK_ISSUER=https://clerk.datameesters.nl

# --- Ollama ---
OLLAMA_DOCKER_TAG=latest

# --- Telemetry ---
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
