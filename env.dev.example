# Copia este archivo a .env.dev y edita según necesites
# .env.dev está en .gitignore — nunca se sube a git

# Backend ClapNClaw (por defecto apunta a staging)
CLAPNCLAW_API_URL=https://api-staging.clapnclaw.io

# Secret del workspace para APIs de billing/tokens (opcional para dev básico)
CLAPNCLAW_WORKSPACE_SECRET=
